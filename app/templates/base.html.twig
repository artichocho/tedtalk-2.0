<!DOCTYPE html>
<html lang="{{ locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="Site de conférence satirique avec design professionnel.">
        <title>{% block title %}TEDx Satire{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 128 128'%3E%3Ctext y='1.05em' font-size='96'%3E%F0%9F%8E%A4%3C/text%3E%3C/svg%3E">
        {% block stylesheets %}
            <script src="https://cdn.tailwindcss.com"></script>
            <script>
                tailwind.config = {
                    theme: {
                        extend: {
                            colors: {
                                tedred: "#E62B1E",
                                tedrose: "#F97373",
                                tedink: "#0B1120",
                                tedline: "#334155"
                            },
                            boxShadow: {
                                panel: "0 18px 38px -26px rgba(0, 0, 0, 0.65)"
                            }
                        }
                    }
                };
            </script>
        {% endblock %}

        {% block javascripts %}
            <script src="/assets/site.js" defer></script>
        {% endblock %}
    </head>
    <body class="min-h-screen bg-slate-950 text-slate-100 selection:bg-tedred/80 selection:text-white">
        {% block body %}{% endblock %}
    </body>
</html>
