{% extends 'talk/_shell.html.twig' %}

{% block title %}Billetterie | TEDx Satire{% endblock %}

{% block page %}
    <section class="rounded-3xl border border-white/10 bg-slate-900/65 p-6 shadow-panel sm:p-10">
        <h1 class="inline-flex items-center gap-2 text-3xl font-bold sm:text-5xl">Billetterie</h1>
        <p class="mt-3 max-w-3xl text-slate-300">
            Choisissez votre niveau de sérieux : du simple échauffement au standing ovulation.
        </p>
        <div class="mt-8 grid gap-6 lg:grid-cols-3">
            {% for ticket in content.tickets %}
                <article class="group relative flex min-h-96 flex-col rounded-2xl border {{ ticket.highlight|default(false) ? 'border-red-400/50 ring-1 ring-red-400/40' : 'border-white/10' }} bg-slate-800/45 p-6 shadow-panel transition-all duration-300 hover:-translate-y-1 hover:border-white/25 hover:shadow-[0_24px_48px_-28px_rgba(0,0,0,0.85)] hover:ring-1 hover:ring-white/10">
                    <p class="text-xs uppercase tracking-[0.16em] text-slate-400">{{ ticket.tagline }}</p>
                    <h2 class="mt-3 text-2xl font-bold">{{ ticket.name }}</h2>
                    <p class="mt-2 text-4xl font-black text-tedred">{{ ticket.price }}</p>
                    <p class="mt-1 text-xs text-slate-400">Tarif TTC - données purement événementielles</p>

                    <ul class="mt-6 grow space-y-2 text-sm text-slate-200">
                        {% for perk in ticket.perks %}
                            <li class="rounded-lg border border-white/10 bg-slate-900/55 px-3 py-2">{{ perk }}</li>
                        {% endfor %}
                    </ul>

                    <p class="mt-4 text-[11px] leading-snug text-slate-500 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                        Ce pass ne remplace pas le consentement, évidemment.
                    </p>
                    {% if ticket.highlight|default(false) %}
                        <button type="button" class="js-fake-checkout mt-3 w-full rounded-lg bg-tedred px-4 py-3 text-center text-sm font-semibold text-white hover:bg-red-500"{% if ticket.billet_url is defined and ticket.billet_url %} data-billet-url="{{ ticket.billet_url|e('html_attr') }}"{% endif %}>
                            Sélectionner ce pass
                        </button>
                    {% else %}
                        <button type="button" class="js-fake-checkout mt-3 w-full rounded-lg border border-white/20 px-4 py-3 text-sm font-semibold hover:border-white/40"{% if ticket.billet_url is defined and ticket.billet_url %} data-billet-url="{{ ticket.billet_url|e('html_attr') }}"{% endif %}>
                            Sélectionner ce pass
                        </button>
                    {% endif %}
                </article>
            {% endfor %}
        </div>
    </section>

    <div id="fake-checkout-overlay" class="fixed inset-0 z-[55] hidden items-center justify-center bg-black/75 p-4" aria-hidden="true">
        <div class="w-full max-w-sm rounded-2xl border border-white/15 bg-slate-900 p-6 shadow-panel" role="dialog" aria-labelledby="fake-checkout-title">
            <h2 id="fake-checkout-title" class="text-base font-semibold text-slate-100">Traitement du paiement</h2>
            <p class="mt-1 text-xs text-slate-500">Connexion sécurisée (fictionnelle) en cours.</p>
            <div class="mt-4 h-2.5 w-full overflow-hidden rounded-full bg-slate-800">
                <div id="fake-checkout-bar" class="h-full w-0 rounded-full bg-tedred"></div>
            </div>
            <p id="fake-checkout-status" class="mt-4 hidden text-sm text-slate-300">
                Paiement simulé avec succès. La banque a souri.
            </p>
            <div id="fake-checkout-billet-wrap" class="mt-4 hidden flex justify-center">
                <a id="fake-checkout-billet" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex rounded-lg bg-tedred px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-500">
                    Voir mon billet
                </a>
            </div>
            <button type="button" id="fake-checkout-close" class="mt-4 w-full rounded-lg border border-white/25 bg-slate-800 px-4 py-2 text-sm font-medium hover:bg-slate-700">
                Fermer
            </button>
        </div>
    </div>
{% endblock %}
