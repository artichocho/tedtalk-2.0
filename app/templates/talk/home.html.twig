{% extends 'talk/_shell.html.twig' %}

{% block title %}{{ content.title }} | TEDx Satire{% endblock %}

{% block page %}
    <section class="rounded-3xl border border-white/10 bg-slate-900/65 p-6 shadow-panel sm:p-10">
        <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Session principale</p>
        <h1 class="mt-3 text-3xl font-bold leading-tight sm:text-5xl">{{ content.title }}</h1>
        <p class="mt-4 max-w-3xl text-slate-300 sm:text-lg">{{ content.subtitle }}</p>
        <div class="mt-5 flex flex-wrap gap-2 text-sm text-slate-400">
            <span class="rounded-full border border-white/15 px-3 py-1">{{ content.date }}</span>
            <span class="rounded-full border border-white/15 px-3 py-1">{{ content.location }}</span>
        </div>
        <div class="mt-8 flex flex-col items-start gap-3">
            <a href="{{ nav.schedule }}" class="inline-flex items-center justify-center rounded-lg bg-tedred px-5 py-3 text-sm font-semibold text-white hover:bg-red-500">{{ content.cta }}</a>
            <div class="flex flex-wrap gap-x-4 gap-y-1">
                <button type="button" id="btn-whitepaper" class="text-sm text-slate-400 underline decoration-dotted underline-offset-4 hover:text-slate-200">
                    Télécharger le whitepaper
                </button>
                <button type="button" id="btn-methodologie" class="text-sm text-slate-400 underline decoration-dotted underline-offset-4 hover:text-slate-200">
                    Voir la méthodologie complète
                </button>
            </div>
        </div>
    </section>

    <section class="mt-8 grid gap-5 lg:grid-cols-2">
        <article class="rounded-2xl border border-white/10 bg-slate-900/55 p-6 shadow-panel">
            <h2 class="inline-flex items-center gap-2 text-xl font-semibold">Intervenante vedette</h2>
            <p class="mt-3 text-slate-100">{{ content.speaker }}</p>
            <p class="mt-2 text-sm text-slate-300">{{ content.speaker_bio }}</p>
            <a href="{{ nav.speaker }}" class="mt-4 inline-block text-sm text-red-300 hover:text-red-200">Voir le profil complet</a>
        </article>
        <article class="rounded-2xl border border-white/10 bg-slate-900/55 p-6 shadow-panel">
            <h2 class="inline-flex items-center gap-2 text-xl font-semibold">{{ content.faq_title }}</h2>
            <p class="mt-3 text-sm text-slate-300">{{ content.faq_1 }}</p>
            <p class="mt-2 text-sm text-slate-300">{{ content.faq_2 }}</p>
            <p class="mt-4 text-xs text-slate-400">{{ content.hint }}</p>
        </article>
    </section>

    <section class="mt-8 rounded-2xl border border-white/10 bg-slate-900/55 p-6 shadow-panel">
        <h2 class="inline-flex items-center gap-2 text-xl font-semibold">Fil rouge (et langue rose)</h2>
        <p class="mt-3 text-slate-300">
            Ici, on parle de plaisir avec méthode : moins de freestyle, plus de finesse. Bref, un vrai plan de langue.
        </p>
    </section>

    <section class="mt-8 rounded-2xl border border-emerald-300/25 bg-emerald-950/25 p-6 shadow-panel">
        <h2 class="inline-flex items-center gap-2 text-xl font-semibold text-emerald-200">{{ content.consent_block_title }}</h2>
        <ul class="mt-4 space-y-2 text-sm text-emerald-100/90">
            {% for point in content.consent_points %}
                <li class="rounded-lg border border-emerald-300/20 bg-slate-900/35 px-3 py-2">{{ point }}</li>
            {% endfor %}
        </ul>
        <p class="mt-4 text-xs text-emerald-200/80">
            En bref : le meilleur coup de langue reste celui qui respecte tout le monde.
        </p>
    </section>

    <section id="methodologie-complete" class="scroll-mt-28 mt-10 rounded-2xl border border-dashed border-white/20 bg-slate-900/40 p-6 shadow-panel sm:p-8">
        <p class="text-xs uppercase tracking-[0.16em] text-slate-500">Annexe méthodologique</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-100">Méthodologie complète (version interne)</h2>
        <p class="mt-2 text-sm text-slate-400">Document non classifié, usage conférence uniquement.</p>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-sm text-slate-300">
            <li>Phase 1 - Audit préalable : cartographier les attentes implicites avant toute démonstration terrain.</li>
            <li>Phase 2 - Boucle agile d’itération : un sprint = un feedback, jamais deux sans pause hydratation.</li>
            <li>Phase 3 - KPI de clôture : mesurer le taux de « ah oui, en fait c’est logique » sur une échelle de 1 à standing ovation.</li>
        </ul>
    </section>
{% endblock %}
