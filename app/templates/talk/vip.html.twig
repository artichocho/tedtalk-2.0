{% extends 'talk/_shell.html.twig' %}

{% block title %}{{ content.vip_title }} | TEDx Satire{% endblock %}

{% block page %}
    <section class="mx-auto max-w-2xl rounded-3xl border border-white/10 bg-gradient-to-br from-slate-900 to-slate-950 p-6 shadow-panel sm:p-10">
        <p class="text-xs uppercase tracking-[0.16em] text-slate-400">VIP</p>
        <h1 class="mt-2 inline-flex items-center gap-2 text-3xl font-bold sm:text-4xl">{{ content.vip_title }}</h1>
        <p class="mt-3 text-slate-300">{{ content.vip_desc }}</p>

        <form id="vip-form" class="mt-8 space-y-4">
            <div>
                <label for="badge" class="mb-1 block text-sm text-slate-300">Nom sur le badge</label>
                <input id="badge" name="badge" required class="w-full rounded-lg border border-white/15 bg-slate-900 px-3 py-2 text-slate-100 outline-none focus:border-tedred" />
            </div>
            <div>
                <label for="code" class="mb-1 block text-sm text-slate-300">Code invitation</label>
                <input id="code" name="code" required class="w-full rounded-lg border border-white/15 bg-slate-900 px-3 py-2 text-slate-100 outline-none focus:border-tedred" />
            </div>
            <button type="submit" class="rounded-lg bg-tedred px-5 py-3 text-sm font-semibold text-white hover:bg-red-500">
                {{ content.vip_button }}
            </button>
        </form>

        <p id="vip-result" data-success-message="{{ content.vip_result }}" class="mt-4 hidden rounded-lg border border-emerald-300/20 bg-emerald-900/30 px-3 py-2 text-sm text-emerald-100"></p>
    </section>
{% endblock %}
